{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CitationsDocument",
  "type": "object",
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CitationEntry"
      }
    },
    "pipeline_version": {
      "type": "string"
    }
  },
  "required": [
    "pipeline_version",
    "entries"
  ],
  "$defs": {
    "BBox": {
      "type": "object",
      "properties": {
        "height": {
          "type": "number",
          "format": "float"
        },
        "page": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "width": {
          "type": "number",
          "format": "float"
        },
        "x": {
          "type": "number",
          "format": "float"
        },
        "y": {
          "type": "number",
          "format": "float"
        }
      },
      "required": [
        "page",
        "x",
        "y",
        "width",
        "height"
      ]
    },
    "CitationEntry": {
      "type": "object",
      "properties": {
        "confidence": {
          "type": "number",
          "format": "float"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "marker": {
          "type": [
            "string",
            "null"
          ]
        },
        "mentions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Mention"
          }
        },
        "raw_text": {
          "type": "string"
        },
        "resolved": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResolvedCitation"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "raw_text",
        "confidence"
      ]
    },
    "Mention": {
      "type": "object",
      "properties": {
        "bbox": {
          "anyOf": [
            {
              "$ref": "#/$defs/BBox"
            },
            {
              "type": "null"
            }
          ]
        },
        "object_id": {
          "description": "The paragraph/sentence object containing this in-text citation.",
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "object_id"
      ]
    },
    "ResolvedCitation": {
      "type": "object",
      "properties": {
        "arxiv_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "doi": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolved_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "venue": {
          "type": [
            "string",
            "null"
          ]
        },
        "year": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        }
      },
      "required": [
        "source"
      ]
    }
  }
}
